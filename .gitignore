# =============================================
# Root .gitignore for resume-analyzer
# =============================================

# Maven build output
backend/target/
*.class
*.jar
*.war

# Frontend dependencies and build
frontend/node_modules/
frontend/dist/
frontend/build/

# IDE and editor files
.idea/
*.iml
.vscode/
*.eclipse
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/
