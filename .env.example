# ── Database (PostgreSQL) ─────────────────────────────────────
# On Render: set these in the Environment Variables panel.
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
# Full PostgreSQL JDBC URL — overrides the default in application.properties
SPRING_DATASOURCE_URL=jdbc:postgresql://your-db-host:5432/resumeanalyzer

# ── AI ───────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key

# ── App Auth (single admin user) ────────────────────────────
# REQUIRED: must be set before deployment — no default is baked in.
APP_USERNAME=admin
APP_PASSWORD=your_secure_password

# ── URLs ─────────────────────────────────────────────────────
FRONTEND_URL=https://your-domain.com
APP_CORS_ORIGINS=https://your-domain.com

# ── OAuth2 (optional — Google only, leave blank to disable) ─
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
