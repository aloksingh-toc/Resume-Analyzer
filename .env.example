# ── Database ────────────────────────────────────────────────
DB_USERNAME=SYSTEM
DB_PASSWORD=your_db_password
SPRING_DATASOURCE_URL=jdbc:oracle:thin:@your-db-host:1521/freepdb1

# ── AI ───────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key

# ── App Auth (single admin user) ────────────────────────────
APP_USERNAME=admin
APP_PASSWORD=your_secure_password

# ── URLs ─────────────────────────────────────────────────────
FRONTEND_URL=https://your-domain.com
APP_CORS_ORIGINS=https://your-domain.com

# ── OAuth2 (optional — leave blank to disable) ───────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
